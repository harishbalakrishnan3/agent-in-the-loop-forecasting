# Copy to .env (gitignored) and fill in. Never commit real secrets.

# LLM provider selection (feature 006): the backend prefers the Anthropic API when
# ANTHROPIC_API_KEY is set, and otherwise falls back to AWS Bedrock when AWS_ACCESS_KEY_ID is set.
# If NEITHER is configured, a run fails fast with a clear message before doing any work.
# Set exactly one (or both — Anthropic wins).

# Anthropic Claude — primary LLM for the analyst agent (PREFERRED when set)
ANTHROPIC_API_KEY=

# Changepoint POC — model IDs (no provider default is hardcoded in code; these MUST be set).
# Intended defaults: visual node = Claude Opus 4.8, ReAct node = Claude Sonnet 4.6, via Bedrock.
VISUAL_MODEL_ID=
REACT_MODEL_ID=

# AWS Bedrock access for the changepoint POC (FALLBACK when ANTHROPIC_API_KEY is unset)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2

# Streamlined agent UI (feature 006): launch the single presentation interface with
#   uv run streamlit run src/ailf/ui/app.py

# LangSmith tracing (optional)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=agent-in-the-loop-forecasting
