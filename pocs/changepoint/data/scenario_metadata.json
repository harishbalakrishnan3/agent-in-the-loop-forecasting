      },
      "row_count": 1000,
      "date_range": {
        "start": "2019-01-01",
        "end": "2021-09-26"
      },
      "train_end": 880,
      "test_horizon": 120,
      "validation_horizon": 120,
      "n_changepoints_to_detect": 2,
      "seasonal_period": 365,
      "split_dates": {
        "train_start": "2019-01-01",
        "train_end_inclusive": "2021-05-29",
        "test_start": "2021-05-30",
        "test_end_inclusive": "2021-09-26"
      },
      "csv_sha256": "2d831f97d0cc095480efc649932e6a6fa30d96e092ed56d614b0ed4f81f72f90",
      "agent_exposure_policy": {
        "agent_may_see_columns": [
          "ds",
          "y"
        ],
        "agent_may_see_rows": "0:880",
        "agent_must_not_see_audit_only": true,
        "agent_must_not_see_test_targets": true
      },
      "audit_only": {
        "note": "Two real structural level shifts occur in training, with the latest close to the forecast origin. Truncating to detected changepoint windows removes the annual seasonal history.",
        "true_injected_boundaries": [
          610,
          700
        ],
        "expected_intervention_family": "full_history_step_regressor"
      }
    },
